{
  "name": "vinaya-workspace",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "cd apps/web && npx next dev -p 3000",
    "build": "cd apps/web && npx next build",
    "lint": "cd apps/web && npx next lint",
    "api:dev": "python -m uvicorn apps.api.main:app --host 127.0.0.1 --port 4010"
  }
}
